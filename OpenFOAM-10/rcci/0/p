FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0";
    object      p;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 -1 -2 0 0 0 0];

internalField   uniform 5913650;

boundaryField
{
    left
    {
        type            cyclic;
    }
    right
    {
        type            cyclic;
    }
    top
    {
        type            waveTransmissive;
        gamma           1.4;
        fieldInf        5913650;
        lInf            1;
        value           uniform 5913650;
    }
    bottom
    {
        type            waveTransmissive;
        gamma           1.4;
        fieldInf        5913650;
        lInf            1;
        value           uniform 5913650;
    }
    frontAndback
    {
        type            empty;
    }
}


