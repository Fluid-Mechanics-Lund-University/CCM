FoamFile
{
    version         2;
    format          ascii;
    class           dictionary;
    location        "constant";
    object          chemistryProperties;
}


chemistryType
{
    solver          ode;
    method          CCM;//clean; // chemistryModel (standard in OpenFOAM 7)
}

chemistry       on;

initialChemicalTimeStep 1e-7;

odeCoeffs
{
    solver          seulex;
    absTol          1e-08;
    relTol          0.1;
}



CCM
