FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      chemistryProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
chemistryType
{
    solver          ode;//ode;
    method          CCM;//clean; // chemistryModel (standard in OpenFOAM 7)
}

chemistry       on;
// jacobian exact;
initialChemicalTimeStep 1e-10;

EulerImplicitCoeffs
{
    cTauChem        1;
    equilibriumRateLimiter off;
}

odeCoeffs
{
    solver          seulex;
    absTol          1e-12;
    relTol          1e-1;
}

CCM
{
    nSlice                50;
    ignoreMin            1e-8;
    optimizedODE         true;
}

#include "reactions"

