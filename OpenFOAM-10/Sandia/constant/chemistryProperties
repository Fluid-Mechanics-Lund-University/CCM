FoamFile
{
    version         2;
    format          ascii;
    class           dictionary;
    location        "constant";
    object          chemistryProperties;
}


chemistryType
{
    solver          ode;
    method          CCM;//clean; // chemistryModel (standard in OpenFOAM 7)
}

chemistry       on;

log             off;

initialChemicalTimeStep 1e-7;

odeCoeffs
{
    solver          seulex;
    absTol          1e-08;
    relTol          0.1;
}

importantSpecies
{
    CO2             ;
    H2O             ;
    CH4             ;
    O2              ;
}

CCM
{
    // Initialization mode (manual or default)
    mode                 default;  // Test default mode: auto-populate all species + T
    nSlice                50;
    ignoreMin            1e-8;
    optimizedODE         true;
    disableFastChemAlloc false;

