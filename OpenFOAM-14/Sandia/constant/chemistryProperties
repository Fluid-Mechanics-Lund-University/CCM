FoamFile
{
    format          ascii;
    class           dictionary;
    location        "constant";
    object          chemistryProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //


type            CCM;

chemistry       on;

initialChemicalTimeStep 1e-7;

ode
{
    solver          seulex;
    absTol          1e-08;
    relTol          0.1;
}

CCM
{
    nSlice                50;
    ignoreMin            1e-6;
    optimizedODE         true;
}
